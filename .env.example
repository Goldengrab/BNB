# ============================================================
# AEQUITAS — Required Environment Variables
# ============================================================
# Copy this file to .env for local development.
# In Vercel: set these in Project → Settings → Environment Variables.

# --- Anthropic API ---
# Your Anthropic API key. Used server-side ONLY (never exposed to client).
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- CORS Origin ---
# The exact deployed URL of your Vercel app (no trailing slash).
# Example: https://bnb-mu-murex.vercel.app
# In local dev, leave this blank — all origins will be allowed.
ALLOWED_ORIGIN=

# --- Database (Turso LibSQL) ---
# Your Turso database connection URL and auth token.
DATABASE_URL=
DATABASE_AUTH_TOKEN=
